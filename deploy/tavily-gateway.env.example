# Copy to /opt/tavily-gateway/tavily-gateway.env and adjust, OR set these in
# the systemd unit's [Service] Environment= lines. The service runs as the
# unprivileged `tavily` user; paths below must be readable/writable by it.

# REQUIRED: bearer token that thin clients must present. Generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
TAVILY_GATEWAY_TOKEN=

# Path to the JSON array of tvly-... keys on the gateway host.
# Recommended: /etc/tavily/keys.json, mode 640, owner root:tavily.
TAVILY_KEYS_FILE=/etc/tavily/keys.json

# Where the usage cache lives (created on first run; must be writable by tavily).
TAVILY_USAGE_CACHE=/var/lib/tavily/usage_cache

# How long (seconds) to trust the cached "best key" before re-querying /usage.
TAVILY_CACHE_TTL=300

# Backstop limits: max simultaneous tvly subprocesses, and the wall-clock kill
# deadline (seconds) for a single exec. Set EXEC_TIMEOUT >= client timeout.
TAVILY_MAX_CONCURRENT=8
TAVILY_EXEC_TIMEOUT=600

# Seconds to skip a key after an auth/quota failure before trying it again.
TAVILY_KEY_COOLDOWN=60

# Bind settings. 0.0.0.0 exposes the gateway publicly; pair with the token
# and (recommended) a firewall/HTTPS reverse proxy in production.
TAVILY_GATEWAY_HOST=0.0.0.0
TAVILY_GATEWAY_PORT=18790

# The tvly binary name/path the gateway spawns. Must be reachable by the
# tavily user (see tavily-gateway.service for setup notes).
TVLY_BIN=tvly